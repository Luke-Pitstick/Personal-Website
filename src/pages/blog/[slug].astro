---
import Layout from '../../layouts/Layout.astro';
import { SITE_SHELL } from '../../components/SectionChrome';
import { formatBlogDate, getBlogPosts } from '../../lib/blog';

export async function getStaticPaths() {
	const posts = await getBlogPosts();

	return posts.map((post) => ({
		params: { slug: post.slug },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = post;
---

<Layout title={`${post.title} | Luke Pitstick`} description={post.description || post.title}>
	<main id="main-content" class="blog-page min-h-screen pt-24 text-[#101617] sm:pt-28">
		<article class={`${SITE_SHELL} blog-article-shell pb-20 md:pb-24`}>
			<a href="/blog/" class="focus-ring blog-back-link">All Posts</a>
			<header class="blog-article-header">
				<p class="blog-post-meta">{formatBlogDate(post.date)}</p>
				<h1>{post.title}</h1>
				{post.description ? <p>{post.description}</p> : null}
			</header>
			<div class="blog-article prose">
				<Content />
			</div>
		</article>
	</main>
</Layout>
