---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.jsx';
import About from '../components/About.jsx';
import Projects from '../components/Projects.jsx';
import Contact from '../components/Contact.jsx';
---

<Layout title="Luke Pitstick | Home">
	<main id="main-content">
		<div id="home" class="scroll-mt-24">
			<Hero client:load />
		</div>
		<div class="relative z-10 bg-white/70 backdrop-blur-sm">
			<div id="about" class="scroll-mt-24">
				<About client:visible />
			</div>
			<div id="projects" class="scroll-mt-24">
				<Projects client:visible />
			</div>
			<div id="contact" class="scroll-mt-24">
				<Contact client:visible />
			</div>
		</div>
	</main>
</Layout>
