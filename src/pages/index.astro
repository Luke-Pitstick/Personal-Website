---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.jsx';
import HeroContent from '../components/HeroContent.astro';
import { AboutIntro, ExperienceSection } from '../components/About.jsx';
import Projects from '../components/Projects.jsx';
import Contact from '../components/Contact.jsx';

const portraitSizes = '(min-width: 768px) 280px, 100vw';
const portraitAvifSrcSet =
	'/pictureofme-256.avif 256w, /pictureofme-384.avif 384w, /pictureofme-512.avif 512w, /pictureofme-768.avif 768w';
const ditheredHeroBackgroundSrc = '/background-dithered.webp';
const ditheredHeroMountainsSrc = '/hero-mountains.webp';
---

<Layout title="Luke Pitstick | Home">
	<link
		slot="head"
		rel="preload"
		as="image"
		type="image/webp"
		href={ditheredHeroBackgroundSrc}
	/>
	<link
		slot="head"
		rel="preload"
		as="image"
		type="image/webp"
		href={ditheredHeroMountainsSrc}
		fetchpriority="low"
		media="(prefers-reduced-motion: no-preference)"
	/>
	<link
		slot="head"
		rel="preload"
		as="image"
		type="image/avif"
		href="/pictureofme-384.avif"
		imagesrcset={portraitAvifSrcSet}
		imagesizes={portraitSizes}
		fetchpriority="high"
	/>
	<main id="main-content">
		<section
			id="home"
			class="scroll-mt-16 relative grid min-h-screen overflow-hidden bg-[#f8f7f1] px-4 text-[#101617]"
		>
			<div class="dithered-hero dithered-hero--static" aria-hidden="true">
				<div class="dithered-hero-shade"></div>
			</div>
			<HeroContent />
			<Hero client:load />
		</section>
		<div class="relative z-10 flex min-h-screen flex-col border-t-4 border-[#101617] bg-[#f8f7f1]/92 shadow-[0_-10px_0_rgba(255,58,18,0.9)] backdrop-blur-sm">
			<div class="flex flex-1 flex-col">
				<div id="about" class="scroll-mt-24">
					<AboutIntro client:visible />
				</div>
				<div id="projects" class="scroll-mt-16">
					<Projects client:visible />
				</div>
				<div id="experience" class="scroll-mt-16 flex-1">
					<ExperienceSection client:visible />
				</div>
			</div>
			<div id="contact" class="mt-auto">
				<Contact client:visible />
			</div>
		</div>
	</main>
</Layout>
